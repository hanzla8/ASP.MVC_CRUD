@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between">
    <h5>Products</h5>
        <a class="btn btn-danger" asp-action="Create">Create New</a>
</div>

@if(TempData["Message"] != null)
{
    <div class="alert alert-primary mt-3" role="alert">
        @TempData["Message"]
    </div>
}

<div class="row">
    @foreach(var product in Model)
    {
        <div class="col-md-3 mx-3 my-3 border shadow">
            <div>

                <img class="w-100 h-50" src="@product.Image" />
               <div class="p-2">
                    <h6>
                        @product.Name
                    </h6>
                    <p>
                        @product.CreateAt.ToString("M");
                    </p>
                    <p>
                        @product.Description
                    </p>
                    <a class="btn btn-warning" asp-action="Update" asp-route-id="@product.Id">Edit</a>
                    @* <a class="btn btn-danger" asp-action="Delete" asp-route-id="@product.Id">Delete</a> *@
                    <button class="btn btn-danger" type="button" onclick="deleteProduct(@product.Id)">Delete</button>
               </div>

            </div>
        </div>
    }
</div>


