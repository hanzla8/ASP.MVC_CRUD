@model Product
@{
    ViewData["Title"] = "Delete Product" + Model.Name;
}

<h5 class="mb-4">
    Delete Product
</h5>

<form asp-action="Delete">

   <h4 class="mb-3">
        Are you sure you want to delete this product: <strong>@Model.Name</strong> ?
   </h4>

    <button class="btn btn-primary" type="submit">Delete</button>
    <a class="btn btn-success" asp-action="Index">Back</a>

</form>
